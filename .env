# Gemini API Configuration
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
# Optional: LibreTranslate Configuration (for self-hosted translation)
# If not configured, Gemini will be used for translation
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=your_api_key

# Database URL (SQLite for local development — change to postgresql:// for production)
DATABASE_URL="file:./dev.db"

# App Configuration
NEXT_PUBLIC_APP_NAME=PugArch FSM Support
NODE_ENV=development

# SMTP Email Alert Configuration (for support ticket notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SUPPORT_ALERT_EMAIL=

# Dashboard Configuration
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

